# Backend Environment Variables
# Copy to .env and fill in values

# Mode: set to "true" for offline testing without external APIs
OFFLINE_MODE=false

# Database
DATABASE_URL=postgresql://lifequest:lifequest_dev@localhost:5432/lifequest

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# External APIs (not needed in OFFLINE_MODE=true)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MAPBOX_SECRET_TOKEN=

# Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# Notifications
FCM_SERVER_KEY=

# Monitoring
SENTRY_DSN=

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
